RESEND_API_KEY=
WAITLIST_TO_EMAIL=
WAITLIST_FROM_EMAIL="Ixercise Waitlist <onboarding@resend.dev>"

# Set the same variables in production hosting.
# Missing RESEND_API_KEY or WAITLIST_TO_EMAIL makes production requests fail instead of silently logging.
NUXT_PUBLIC_SITE_URL=https://www.ixercise.com
NUXT_PUBLIC_UMAMI_WEBSITE_ID=1311d774-7582-4a83-a3ef-0a7727699d6c

# Optional: use an external static form provider instead of /api/waitlist.
NUXT_PUBLIC_WAITLIST_ENDPOINT=
